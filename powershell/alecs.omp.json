{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ .UserName }}",
          "foreground": "#e06c75",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "➜ ",
          "foreground": "#abb2bf",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "folder"
          },
          "template": "{{ .Folder }}",
          "foreground": "#98c379",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "\ue709 ",
            "cache_duration": "none"
          },
          "template": "<#5FAAE8>(</>{{ .HEAD }}<#5FAAE8>)</>",
          "foreground": "#D0666F",
          "type": "git",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "✗",
          "foreground": "#BF616A",
          "type": "exit",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
